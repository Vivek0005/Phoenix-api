## File 3 — `NrtEngine.java`

```java
package com.example.gh_actions_demo1.nrt;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.fasterxml.jackson.databind.node.ObjectNode;
import io.restassured.RestAssured;
import io.restassured.response.Response;
import io.restassured.specification.RequestSpecification;
import org.junit.jupiter.api.Test;
import org.skyscreamer.jsonassert.JSONAssert;
import org.skyscreamer.jsonassert.JSONCompareMode;
import org.springframework.boot.test.context.SpringBootTest;

import java.io.File;
import java.util.Iterator;
import java.util.Map;

import static org.junit.jupiter.api.Assertions.*;

/*
 * NrtEngine — Non Regression Test Engine
 *
 * HOW IT WORKS:
 * 1. Reads request.json        → knows what to send
 * 2. Reads expected-response.json → knows what to expect
 * 3. Reads AUTH_TOKEN from env → knows how to authenticate
 * 4. Reads BASE_URL from env   → knows which environment to hit
 * 5. Fires the real HTTP request
 * 6. Compares actual vs expected using the validation mode
 *
 * TO RUN LOCALLY:
 *   export AUTH_TOKEN=your_token_here
 *   export BASE_URL=https://your-uat-url.com
 *   ./mvnw test -Dtest=NrtEngine
 *
 * TO RUN VIA GITHUB ACTIONS:
 *   Trigger the workflow manually, paste token when prompted.
 */

// We are NOT using @SpringBootTest with RANDOM_PORT here
// because we are hitting a REAL hosted API, not starting
// our own server. We just need the test runner to execute.
@SpringBootTest
public class NrtEngine {

    private final ObjectMapper mapper = new ObjectMapper();

    // Base path where all NRT flow folders live
    private final String NRT_BASE = "src/test/resources/nrt/";

    @Test
    void run_currencyApi_nrt() throws Exception {

        // ── STEP 1: READ ENVIRONMENT VARIABLES ──────────────────────
        // These come from GitHub Actions secrets/inputs at runtime
        // Locally you set them via: export AUTH_TOKEN=xxx

        String authToken = System.getenv("AUTH_TOKEN");
        String baseUrl   = System.getenv("BASE_URL");

        // Fail immediately with clear message if env vars are missing
        assertNotNull(authToken,
            "AUTH_TOKEN environment variable is not set. " +
            "Set it locally or pass it in GitHub Actions.");
        assertNotNull(baseUrl,
            "BASE_URL environment variable is not set. " +
            "Example: https://your-uat-server.com");

        // ── STEP 2: LOAD JSON FILES ──────────────────────────────────
        // Each API flow has its own folder with 2 files
        String flowPath = NRT_BASE + "currencyApi/";

        File requestFile  = new File(flowPath + "request.json");
        File expectedFile = new File(flowPath + "expected-response.json");

        // Guard: if files don't exist, fail with clear message
        assertTrue(requestFile.exists(),
            "Missing file: " + flowPath + "request.json");
        assertTrue(expectedFile.exists(),
            "Missing file: " + flowPath + "expected-response.json");

        // Parse both files into JsonNode (think of it as a JSON object)
        JsonNode requestJson  = mapper.readTree(requestFile);
        JsonNode expectedJson = mapper.readTree(expectedFile);

        // ── STEP 3: PARSE REQUEST DETAILS ───────────────────────────
        // Pull out method and endpoint from request.json
        String method   = requestJson.get("method").asText().toUpperCase();
        String endpoint = requestJson.get("endpoint").asText();
        String fullUrl  = baseUrl + endpoint;

        System.out.println(">> Firing: " + method + " " + fullUrl);

        // ── STEP 4: BUILD THE HTTP REQUEST ───────────────────────────
        // Start building the RestAssured request
        RequestSpecification spec = RestAssured.given()
            .contentType("application/json")
            // Attach the Bearer token from env variable
            .header("Authorization", "Bearer " + authToken);

        // Add query params if they exist in request.json
        // e.g. ?sortBy=ccyCode&sortingOrder=asc
        if (requestJson.has("query_params")) {
            Iterator<Map.Entry<String, JsonNode>> params =
                requestJson.get("query_params").fields();
            while (params.hasNext()) {
                Map.Entry<String, JsonNode> param = params.next();
                spec = spec.queryParam(
                    param.getKey(),
                    param.getValue().asText()
                );
            }
        }

        // Add request body if present and not empty
        // For GET requests this will be empty {}
        JsonNode requestBody = requestJson.get("request_body");
        if (requestBody != null && !requestBody.isEmpty()) {
            spec = spec.body(requestBody.toString());
        }

        // ── STEP 5: FIRE THE REQUEST ─────────────────────────────────
        // Switch on HTTP method and fire accordingly
        Response response = switch (method) {
            case "GET"    -> spec.get(fullUrl);
            case "POST"   -> spec.post(fullUrl);
            case "PUT"    -> spec.put(fullUrl);
            case "DELETE" -> spec.delete(fullUrl);
            case "PATCH"  -> spec.patch(fullUrl);
            default -> throw new IllegalArgumentException(
                "Unsupported HTTP method in request.json: " + method);
        };

        System.out.println(">> Response status: " + response.getStatusCode());
        System.out.println(">> Response body: " +
            response.getBody().asString());

        // ── STEP 6: CHECK STATUS CODE ────────────────────────────────
        // Read expectedStatus from expected-response.json
        int expectedStatus = expectedJson.get("expectedStatus").asInt();

        assertEquals(
            expectedStatus,
            response.getStatusCode(),
            // On failure, print the actual body so you know WHY it failed
            "Status code mismatch. Actual response body was: " +
            response.getBody().asString()
        );

        // ── STEP 7: PARSE ACTUAL RESPONSE ────────────────────────────
        String responseBody = response.getBody().asString();
        ObjectNode actual;

        try {
            // Try to parse response as JSON
            actual = (ObjectNode) mapper.readTree(responseBody);
        } catch (Exception e) {
            // If it's not JSON (HTML error page, plain text etc.)
            // fail with the raw response so you can debug
            fail("Response is not valid JSON. Raw response was: "
                + responseBody);
            return; // compiler needs this after fail()
        }

        // ── STEP 8: APPLY VALIDATION MODE ───────────────────────────
        JsonNode validation   = expectedJson.get("validation");
        String mode           = validation.get("mode").asText().toUpperCase();
        JsonNode fields       = validation.get("fields");
        JsonNode expectedBody = expectedJson.get("expectedResponse");

        System.out.println(">> Validation mode: " + mode);

        switch (mode) {

            case "STRICT" -> {
                // Every single field must match exactly.
                // Extra fields in actual = FAIL
                // Field order matters
                JSONAssert.assertEquals(
                    expectedBody.toString(),
                    actual.toString(),
                    JSONCompareMode.STRICT
                );
            }

            case "LENIENT" -> {
                // All fields in expected must match.
                // Extra fields in actual = OK
                // Field order doesn't matter
                JSONAssert.assertEquals(
                    expectedBody.toString(),
                    actual.toString(),
                    JSONCompareMode.LENIENT
                );
            }

            case "IGNORE" -> {
                // Remove the listed dynamic fields from actual
                // (e.g. timestamp, id change every request)
                // Then compare the rest leniently
                if (fields != null) {
                    fields.forEach(f -> {
                        String fieldName = f.asText();
                        actual.remove(fieldName);
                        System.out.println(">> Ignoring field: " + fieldName);
                    });
                }
                JSONAssert.assertEquals(
                    expectedBody.toString(),
                    actual.toString(),
                    JSONCompareMode.LENIENT
                );
            }

            case "CONTAINS" -> {
                // Only check the specific fields listed in "fields"
                // Everything else in actual is completely ignored
                ObjectNode filteredActual   = mapper.createObjectNode();
                ObjectNode filteredExpected = mapper.createObjectNode();

                if (fields != null) {
                    fields.forEach(f -> {
                        String fieldName = f.asText();
                        // Pick only listed fields from actual response
                        if (actual.has(fieldName)) {
                            filteredActual.set(fieldName,
                                actual.get(fieldName));
                        }
                        // Pick only listed fields from expected
                        if (expectedBody.has(fieldName)) {
                            filteredExpected.set(fieldName,
                                expectedBody.get(fieldName));
                        }
                    });
                }
                JSONAssert.assertEquals(
                    filteredExpected.toString(),
                    filteredActual.toString(),
                    JSONCompareMode.LENIENT
                );
            }

            default -> throw new IllegalArgumentException(
                "Unknown validation mode in expected-response.json: " + mode
            );
        }

        System.out.println(">> NRT PASSED for currencyApi");
    }
}
```

